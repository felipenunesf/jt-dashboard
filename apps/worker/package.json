{
  "name": "@jt/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "echo 'no build step — runs via tsx in production for monorepo simplicity'",
    "migrate": "tsx ../../packages/db/src/migrate.ts",
    "start": "pnpm migrate && tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@jt/db": "workspace:*",
    "@jt/shared": "workspace:*",
    "bullmq": "^5.34.10",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
