# ============================================================
# JT Dashboard — Variáveis de ambiente
# Copie para .env e preencha
# ============================================================

# --- Postgres ---
DATABASE_URL=postgres://felipenunesfraga@localhost:5432/jt_dashboard

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth (single-user via env) ---
# Gere um hash com: node -e "console.log(require('bcryptjs').hashSync('SUASENHA', 10))"
ADMIN_EMAIL=felipe@jt.local
ADMIN_PASSWORD_HASH=$2a$10$REPLACE_ME
AUTH_SECRET=gere_uma_string_aleatoria_aqui_minimo_32_chars

# --- Web ---
WEB_PORT=3000
NEXTAUTH_URL=http://localhost:3000

# --- Worker ---
WORKER_PORT=4000
WORKER_PUBLIC_URL=http://localhost:4000

# --- Meta Marketing API ---
# Cadastre uma ou mais accounts em settings (DB) ou aqui via JSON
# Exemplo: META_ACCOUNTS='[{"account_id":"act_123","name":"JT Principal","access_token":"EAAxxx","pixel_ids":["111"]}]'
META_ACCOUNTS=

# --- Meta CAPI ---
# Em produção, deixe vazio. Em dev, use código de teste do Events Manager
META_TEST_EVENT_CODE=

# --- Z-API (preencher na Fase 3) ---
# Lista de instâncias separadas por vírgula no formato instanceId:token:clientToken
# Exemplo: ZAPI_INSTANCES=3D8B...:abc123...:client...,3D8C...:def456...:client...
ZAPI_INSTANCES=

# --- GHL (preencher na Fase 5) ---
GHL_PRIVATE_TOKEN=
GHL_LOCATION_ID=

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=development
