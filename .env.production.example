# ============================================================================
# JT Dashboard — Production environment template
# Copie para .env.production e preencha. NUNCA commitar este arquivo.
# ============================================================================

# --- Postgres ---
POSTGRES_PASSWORD=mude_aqui_uma_senha_forte_min_20_chars

# --- Auth (single-user, gerar hash com hash-password.mjs) ---
ADMIN_EMAIL=felipe@jt.com.br
# Importante: $ no hash bcrypt precisa ser escapado como $$ no docker-compose
ADMIN_PASSWORD_HASH=$$2a$$10$$REPLACE_ME_WITH_BCRYPT_HASH
AUTH_SECRET=gere_uma_string_aleatoria_minimo_32_caracteres_aqui_xxxxx

# --- Meta Marketing API ---
META_SYSTEM_USER_TOKEN=EAAxxx_seu_token_aqui
META_ACCOUNTS=[{"account_id":"act_1096702648134272","name":"CA03","pixel_ids":["1545838446017240"]},{"account_id":"act_345426295001979","name":"CA02","pixel_ids":["1545838446017240"]}]
META_API_VERSION=v22.0

# --- Meta CAPI ---
# DEIXE VAZIO em produção (eventos vão pro pipeline real)
META_TEST_EVENT_CODE=
# DESLIGUE em produção
META_CAPI_DRY_RUN=false

# --- Z-API (preencher quando criar a conta) ---
ZAPI_INSTANCES=
WHATSAPP_WEBHOOK_SECRET=

# --- GHL (preencher quando criar a Private Integration) ---
GHL_PRIVATE_TOKEN=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

# --- Backup ---
BACKUP_RETENTION_DAYS=14
