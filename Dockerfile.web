# syntax=docker/dockerfile:1.7
# Web (Next.js 15 dashboard) — multi-stage build com standalone output

FROM node:24-alpine AS deps
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/db/package.json ./packages/db/
COPY packages/shared/package.json ./packages/shared/

RUN pnpm install --frozen-lockfile

# ============================================================================

FROM node:24-alpine AS builder
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /app

# Copia node_modules + symlinks
COPY --from=deps /app ./

# Copia source
COPY apps/web ./apps/web
COPY packages/db ./packages/db
COPY packages/shared ./packages/shared

ENV NEXT_TELEMETRY_DISABLED=1 \
    NODE_ENV=production \
    AUTH_SECRET=build_time_placeholder_will_be_overridden_in_runtime_xxxxxxxxxx \
    DATABASE_URL=postgres://placeholder@localhost:5432/placeholder

RUN pnpm --filter @jt/web build

# ============================================================================

FROM node:24-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Standalone copia todas as deps necessárias do monorepo (incluindo @jt/db, @jt/shared)
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

USER nextjs

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD wget --quiet --spider --tries=1 --timeout=3 http://127.0.0.1:3000/api/health || exit 1

EXPOSE 3000
CMD ["node", "apps/web/server.js"]
